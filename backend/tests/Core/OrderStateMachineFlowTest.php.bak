    public function testCheckCanReturnsDetailedErrorForInvalidTransition()
    {
        $sm = $this->createStateMachine(OrderStatus::PENDING);

        $result = $sm->checkCan(OrderEvent::SHIP);
        $this->assertFalse($result['allowed']);
        $this->assertEquals('invalid_transition', $result['error_code']);
        $this->assertNotEmpty($result['error_message']);
        $this->assertNotEmpty($result['suggestion']);
        $this->assertArrayHasKey('allowed_events', $result);
        $this->assertContains(OrderEvent::PAY, $result['allowed_events']);
        $this->assertContains(OrderEvent::CANCEL, $result['allowed_events']);
    }

    public function testGetValidationErrorsReturnsStructuredErrors()
    {
        $sm = $this->createStateMachine(OrderStatus::COMPLETED);

        $errors = $sm->getValidationErrors(OrderEvent::SHIP);
        $this->assertNotEmpty($errors);
        $this->assertEquals('terminal_status', $errors['code']);
        $this->assertNotEmpty($errors['message']);
        $this->assertNotEmpty($errors['suggestion']);

        $sm2 = $this->createStateMachine(OrderStatus::PENDING);
        $noErrors = $sm2->getValidationErrors(OrderEvent::PAY);
        $this->assertEmpty($noErrors);
    }

    public function testForceTransitionWhenDisabled()
    {
        $sm = $this->createStateMachine(OrderStatus::PENDING, ['allow_force_transition' => false]);

        $this->expectException(StateMachineException::class);
        $this->expectExceptionCode(StateMachineException::CODE_VALIDATION_FAILED);
        $sm->forceTransition(OrderStatus::COMPLETED);
    }

    public function testForceTransitionWhenEnabled()
    {
        $sm = $this->createStateMachine(OrderStatus::PENDING, ['allow_force_transition' => true]);

        $result = $sm->forceTransition(OrderStatus::COMPLETED, 'admin_001', 'Force complete');
        $this->assertTrue($result->isSuccess());
        $this->assertEquals(OrderStatus::PENDING, $result->getFromStatus());
        $this->assertEquals(OrderStatus::COMPLETED, $result->getToStatus());
        $this->assertEquals('force_transition', $result->getEvent());
        $this->assertEquals(OrderStatus::COMPLETED, $sm->getCurrentStatus());
    }

    public function testForceTransitionWithInvalidStatus()
    {
        $sm = $this->createStateMachine(OrderStatus::PENDING, ['allow_force_transition' => true]);

        $this->expectException(StateMachineException::class);
        $this->expectExceptionCode(StateMachineException::CODE_INVALID_STATUS);
        $sm->forceTransition('invalid_status');
    }

    public function testSyncStatus()
    {
        $sm = $this->createStateMachine(OrderStatus::PENDING);

        $sm->syncStatus(OrderStatus::PA